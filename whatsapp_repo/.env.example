# App
APP_NAME=GastoZap
DEBUG=false
API_SECRET_KEY=change-me-to-a-random-secret
CORS_ORIGINS=http://localhost:3000
PORT=8000

# Database (Easypanel: aceita postgres:// — convertido automaticamente para asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/gastozap

# Evolution API
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=gastozap
# Aceita WEBHOOK_SECRET ou EVOLUTION_API_TOKEN (alias do Setup_Ambiente.md)
WEBHOOK_SECRET=your-webhook-secret

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# Security — aceita ALLOWED_PHONE_NUMBERS ou WHITELIST_NUMBERS
ALLOWED_PHONE_NUMBERS=5511999999999
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me

# Business rules
ALWAYS_CONFIRM_MODE=true
HIGH_VALUE_THRESHOLD=500.0
# Aceita ALERT_TIME=20:00 ou DAILY_ALERT_HOUR + DAILY_ALERT_MINUTE
ALERT_TIME=20:00
RETRY_LIMIT=3
CARD_EXPIRY_ALERT_MONTHS=3

# Redis (optional)
REDIS_URL=redis://redis:6379/0
USE_REDIS_QUEUE=false
